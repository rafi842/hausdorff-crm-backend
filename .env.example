# Server
PORT=3001
NODE_ENV=production

# Security
JWT_SECRET=

# Database
DB_PATH=./crm.db

# CORS (comma-separated origins, or * for dev)
CORS_ORIGIN=http://localhost:5173

# Backup
BACKUP_DIR=./backups
BACKUP_KEEP_COUNT=7

# WhatsApp Cloud API (Meta) — required for /api/whatsapp/* to function
# Stage 1: only the four WHATSAPP_* + RAFI_USER_ID are needed (echo-bot mode).
# Stage 2 will additionally require ANTHROPIC_API_KEY + OPENAI_API_KEY.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=crm-wa-token-change-me
RAFI_USER_ID=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
